# CAITECH Wi-Fi Hotspot Billing Platform
# Environment Configuration

# ===========================================
# DATABASE
# ===========================================
MONGO_URL="mongodb://localhost:27017"
DB_NAME="caitech_db"
CORS_ORIGINS="*"

# ===========================================
# AUTHENTICATION
# ===========================================
JWT_SECRET="caitech-jwt-secret-key-change-in-production-2026"

# ===========================================
# M-PESA DARAJA API
# ===========================================
# Environment: 'sandbox' or 'production'
MPESA_ENV="sandbox"

# Get these from Safaricom Daraja Portal:
# Sandbox: https://developer.safaricom.co.ke/MyApps
# Production: Apply via Safaricom Business
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE=""
MPESA_PASSKEY=""

# Callback URL (must be publicly accessible)
# For sandbox testing, use ngrok or similar
MPESA_CALLBACK_URL=""

# ===========================================
# SMS GATEWAY
# ===========================================
# Provider: 'africas_talking' or 'centipid'
SMS_PROVIDER="africas_talking"

# Africa's Talking credentials
# Get from: https://account.africastalking.com/
SMS_API_KEY=""
SMS_USERNAME=""
SMS_SENDER_ID="CAITECH"

# ===========================================
# WHATSAPP (TWILIO)
# ===========================================
# Get from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER=""

# ===========================================
# FREERADIUS
# ===========================================
RADIUS_HOST="localhost"
RADIUS_SECRET="testing123"
RADIUS_AUTH_PORT="1812"
RADIUS_ACCT_PORT="1813"
